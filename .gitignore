# Python
__pycache__/
*.pyc
.venv/

# Runtime state (regenerated by scripts)
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/compile.log
scripts/session-flush-*
scripts/flush-context-*

# Generated/user content (built up per-user by hooks, scripts, and manual ingest).
# These paths are symlinks to a separate content repo set up by
# scripts/link-content.py. No trailing slashes — gitignore patterns with
# trailing slashes match directories only, not symlink blobs.
raw
knowledge
notes

# Reports (regenerated by lint)
reports/

# uv lock (regenerated by uv sync; lives at repo root, not under scripts/)
uv.lock

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

.obsidian/
